# MAIA OpenBB Service — environment variables
# Set these in the Railway service dashboard (not committed to git).

# Bearer token that guards this service — must match OPENBB_TOKEN in the MAIA app env.
OPENBB_API_KEY=

# FMP (Financial Modeling Prep) data provider — needed because Railway blocks yfinance.
# Free tier: 250 API calls/day. Sign up: https://financialmodelingprep.com/register
FMP_API_KEY=
# OpenBB also reads this as its own credential name (we mirror it in main.py):
OPENBB_FMP_API_KEY=

# Railway sets PORT automatically — do not set this.
# PORT=8080
