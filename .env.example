# ────────────────────────────────────────────────────────────────────────────
# MAIA — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env. NEVER log, print, or send a secret to the model.
# ────────────────────────────────────────────────────────────────────────────

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# MAIA bearer auth (Railway routes + GitHub Actions cron)
MAIA_API_KEY=

# Slack — MAIA's own app (separate from Meridian/JARVIS)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=
SLACK_OWNER_USER_ID=

# Database — on Railway, point at the volume mount path (e.g. /data/maia.db)
DATABASE_URL=./maia.db

# MAIA's public Railway URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ElevenLabs voice
ELEVENLABS_API_KEY=
MAIA_VOICE_ID=
# DIANA roleplay voice — Simon (corporate storyteller)
ELEVENLABS_VOICE_ID=Ln7FbpLNuLn2OdYq2w7S
# MAIA orchestrator voice — Ava
ELEVENLABS_AVA_VOICE_ID=wCizWKvnaS3LOIUwHo98

# CASSANDRA — market & regulatory research
BRAVE_API_KEY=

# DEMETER — personal portfolio (informational only, no trading)
# Twelve Data: free tier covers US equities (NASDAQ/NYSE) + GBP/USD FX.
TWELVE_DATA_API_KEY=
# Alpha Vantage: covers LSE ETFs (VWRP.LON, VDPG.LON). Railway-safe (API-key auth).
# Free key (no card): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
# OpenBB: future Research Terminal data source (deploy OpenBB Platform to Railway first)
OPENBB_URL=
OPENBB_TOKEN=

# LUNA — calendar / meeting prep (add when building LUNA, T2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# IRIS — LinkedIn news relay (T3, shelved until deVere compliance sign-off)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
DRY_RUN=true

# IRIS — image generation (gpt-image-1)
OPENAI_API_KEY=

# ── Dashboard auth (D0) ──────────────────────────────────────────────────────
# Bcrypt hash of your chosen dashboard password. Generate with:
#   node -e "const b=require('bcryptjs');b.hash('YOUR_PASSWORD',12).then(h=>console.log(h))"
# Paste ONLY the hash here — never the plaintext.
DASHBOARD_PASSWORD_HASH=
# 32+ random chars for HMAC session signing. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
